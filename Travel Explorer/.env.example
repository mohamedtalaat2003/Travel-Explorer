# =============================================================================
# Travel Explorer API - configuration example
# =============================================================================
# ASP.NET Core does NOT read .env files automatically. This file documents the
# configuration keys the API needs. Provide them in ANY of these ways:
#
#   1. User Secrets (recommended for local dev, keeps secrets out of git):
#        dotnet user-secrets set "ConnectionStrings:DefaultConnection" "Host=..."
#   2. appsettings.Development.json (already contains safe local dev defaults)
#   3. Environment variables in the "Section__Key" form shown below
#      (double underscore "__" maps to the ":" config separator).
#
# Never commit real secrets. The values below are placeholders/examples.
# Required keys are marked [REQUIRED]; the rest are optional per feature.
# =============================================================================

# --- Database (PostgreSQL) --------------------------------------------------
# [REQUIRED] EF Core connection string. The app auto-applies migrations on start.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=TravelExplorer;Username=postgres;Password=postgres

# --- JWT authentication -----------------------------------------------------
# [REQUIRED] Signing key. Must be long (HMAC-SHA512 needs >= 64 bytes). Change in prod.
JwtSettings__Token=ChangeThisToALongRandomSecretOfAtLeast64BytesForProductionUse_0123456789
# [REQUIRED] Token issuer / audience (any consistent strings).
JwtSettings__Issuer=TravelExplorerAPI
JwtSettings__Audience=TravelExplorerClient
# Access token lifetime (minutes) and refresh token lifetime (days).
JwtSettings__AccessTokenExpirationMinutes=60
JwtSettings__RefreshTokenExpirationDays=7
# Google OAuth (optional - only needed for "Continue with Google").
JwtSettings__GoogleClientId=
JwtSettings__GoogleClientSecret=
# Where the API redirects the browser back to the SPA after Google auth.
JwtSettings__GoogleFrontendRedirectURl=http://localhost:5173/auth/google/register-callback
JwtSettings__GoogleFrontendloginRedirectUrl=http://localhost:5173/auth/google/login-callback

# --- Cloudinary (optional - image uploads) ----------------------------------
# Without these, the /api/Upload endpoints fail; the SPA's upload widgets also
# accept a pasted image URL as a fallback, so content management still works.
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=

# --- Paymob (optional - online payments) ------------------------------------
# Required for real checkout. With mock values the checkout redirect won't complete.
PaymobSettings__PaymentMethodId=mock_payment_method_id
PaymobSettings__PublicKey=mock_public_key
PaymobSettings__Secretkey=mock_secret_key
PaymobSettings__ApiKey=mock_api_key
PaymobSettings__IFrameId=mock_iframe_id
PaymobSettings__CardIntegrationId=mock_card_integration_id
PaymobSettings__HmacSecret=mock_hmac_secret
PaymobSettings__Currency=EGP

# --- Seeded admin account ---------------------------------------------------
# Created on first startup if it does not exist. Change the password for any
# non-local environment.
AdminUser__UserName=admin
AdminUser__Email=admin@travelexplorer.com
AdminUser__Password=Admin@123
AdminUser__FullName=System Administrator

# --- Hosting (optional) -----------------------------------------------------
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=https://localhost:7133;http://localhost:5015
